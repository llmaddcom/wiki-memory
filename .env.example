# 全部变量带 WIKIMEM_ 前缀；见 wiki_memory/config.py

# sqlite 单文件（默认）；换 Postgres:
# WIKIMEM_DATABASE_URL=postgresql+psycopg://user:pass@127.0.0.1:5432/wiki_memory
WIKIMEM_DATABASE_URL=sqlite:///./wiki_memory.db

# 固化/召回所用 LLM（OpenAI 兼容端点）
WIKIMEM_LLM_BASE_URL=http://127.0.0.1:8000/v1
WIKIMEM_LLM_API_KEY=EMPTY
WIKIMEM_LLM_MODEL=your-model-name

# 设置后所有请求须带 X-API-Key；留空不鉴权
WIKIMEM_API_KEY=
